# Database (Neon Serverless Postgres)
DATABASE_URL=postgresql://user:password@host/vibefitai?sslmode=require

# Auth (NextAuth v5)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# AI (Google Gemini — extracción, visión y transcripción)
GEMINI_API_KEY=...

# Cache & Queue (Upstash)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
QSTASH_TOKEN=...
QSTASH_CURRENT_SIGNING_KEY=...
QSTASH_NEXT_SIGNING_KEY=...

# Media Storage (Cloudflare R2)
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=vibefitai-media
R2_PUBLIC_URL=https://media.yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (recuperación de contraseña) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY="xkeysib-..."
EMAIL_FROM="VibeFitAI <no-reply@tudominio.com>"
